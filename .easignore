# EAS CLI resolves ignore rules from the Git repository root.
# Keep this file in sync with the repository and mobile ignore rules.

# Compiled and debug output
*.class
*.log
*.ctxt
.mtj.tmp/
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# JAR packages, except the Gradle wrapper required by Android builds
*.jar
!**/gradle/wrapper/gradle-wrapper.jar

# Dependencies
node_modules/

# Expo output
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/expo-env.d.ts

# Native projects are generated by EAS Prebuild
mobile/android/
mobile/ios/

# Native credentials and local build artifacts
mobile/.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro and debug output
.metro-health-check*
npm-debug.*
yarn-debug.*
yarn-error.*

# Local files and secrets
.DS_Store
*.pem
mobile/.env
mobile/.env*.local
*.tsbuildinfo
mobile/example/
mobile/mesa-firebase-service-account.json.json

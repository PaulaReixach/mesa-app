{
  "expo": {
    "name": "Mesa",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.pauluna.mesa"
    },
    "android": {
      "package": "com.pauluna.mesa",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF8F3",
          "image": "./assets/images/mesa-splash-icon.png",
          "imageWidth": 170,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Mesa necesita acceder a tus fotos para cambiar tu imagen de perfil.",
          "cameraPermission": "Mesa necesita usar la cámara para cambiar tu imagen de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#D56A4A",
          "defaultChannel": "mesa-activity-v2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "515bd901-212b-4d7d-9acc-aefd503dcfba"
      }
    },
    "owner": "paulirei"
  }
}
